{
  "name": "z-ai-image-mcp",
  "version": "1.0.0",
  "description": "MCP server for Z.AI image generation models (GLM-Image, CogView-4)",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "z.ai",
    "image",
    "generation",
    "imagegen",
    "image-generation",
    "mcp-server"
  ],
  "author": "GeorgH93",
  "homepage": "https://github.com/GeorgH93/z_ai_image_gen_mcp#readme",
  "bugs": {
    "url": "https://github.com/GeorgH93/z_ai_image_gen_mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GeorgH93/z_ai_image_gen_mcp.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "z-ai-image-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "tsx": "^4.15.0",
    "dotenv": "^16.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
