# Z.AI API Configuration
# Get your API key from: https://z.ai/manage-apikey/apikey-list
ZAI_API_KEY=your_api_key_here

# Optional: Override default API base URL
# ZAI_API_BASE_URL=https://api.z.ai/api

# Optional: Default model (glm-image or cogview-4-250304)
# ZAI_DEFAULT_MODEL=glm-image

# Optional: Default image size
# ZAI_DEFAULT_SIZE=1280x1280

# Optional: Request timeout in milliseconds
# ZAI_REQUEST_TIMEOUT=60000

# Optional: Maximum retry attempts for transient errors
# ZAI_MAX_RETRIES=3

# Optional: Initial retry delay in milliseconds
# ZAI_RETRY_DELAY=1000
